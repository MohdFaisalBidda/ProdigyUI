#!/usr/bin/env node
const { spawn } = require('child_process');
const path = require('path');

const scriptPath = path.join(__dirname, '..', 'dist', 'index.mjs');
const args = process.argv.slice(2);

const child = spawn('node', [scriptPath, ...args], {
  stdio: 'inherit'
});

child.on('exit', (code) => {
  process.exit(code || 0);
});
